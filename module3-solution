<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Module 3 Solution</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Bootstrap CSS -->
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <nav class="navbar navbar-default">
    <div class="container-fluid">
      <div class="navbar-header">
        <!-- Mobile toggle button -->
        <button type="button" class="navbar-toggle collapsed visible-xs" data-toggle="collapse" data-target="#menu">
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
        </button>
        <a class="navbar-brand" href="#">Food, LLC</a>
      </div>
      <div class="collapse navbar-collapse" id="menu">
        <ul class="nav navbar-nav visible-xs">
          <li><a href="#">Chicken</a></li>
          <li><a href="#">Beef</a></li>
          <li><a href="#">Sushi</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container">
    <h1 class="text-center">Our Menu</h1>
  </div>

  <div class="container-fluid">
    <div class="row">
      <div class="col-xs-12 section">
        <p>
          Welcome to Food, LLC! This is our menu section. Scroll down to see how tall this section is.
          <!-- Repeat text to make it tall -->
        </p>
        <p>
          More filler text... More filler text... More filler text... More filler text... More filler text...
        </p>
        <p>
          Even more filler text to ensure scrolling is required. Keep adding until the section feels tall enough.
        </p>
      </div>
    </div>
  </div>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>
</html>

.section {
  background-color: #f2f2f2;
  min-height: 1000px; /* ensures scrolling */
  padding: 20px;
}

.navbar-nav {
  width: 100%;
  background-color: #ddd;
}

.navbar-nav li a {
  text-align: center;
}
